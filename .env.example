# ShaneBrain Stack — service URLs
# Defaults point to host machine via host.docker.internal (works on Linux Docker with host-gateway).
# For Tailscale: replace with your Pi's Tailscale IP, e.g. 100.x.x.x

# Ollama (local AI inference — runs on Pi at port 11434)
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:1b

# Embedding model (needs to be pulled: ollama pull nomic-embed-text)
EMBED_MODEL=nomic-embed-text

# Weaviate (vector memory — runs on Pi at port 8080)
WEAVIATE_URL=http://host.docker.internal:8080

# Tailscale example (uncomment and set your Pi IP):
# OLLAMA_URL=http://100.x.x.x:11434
# WEAVIATE_URL=http://100.x.x.x:8080
